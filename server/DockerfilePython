FROM python:3.9

WORKDIR /server

# Install Python dependencies
RUN pip install mysql-connector-python fastapi uvicorn pytest httpx

# Copy the server script
COPY server.py .
COPY test_server.py .

EXPOSE 8000

# Run the FastAPI server on container start
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]